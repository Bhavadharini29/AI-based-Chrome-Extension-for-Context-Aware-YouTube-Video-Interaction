{
  "manifest_version": 3,
  "name": "YouTube RAG Chatbot",
  "version": "1.0",
  "description": "Chat with YouTube videos using AI RAG.",
  "permissions": ["activeTab"],
  "host_permissions": ["*://*.youtube.com/*", "http://localhost:8000/*", "http://127.0.0.1:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open YT Chatbot"
  }
}
